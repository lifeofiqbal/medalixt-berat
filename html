<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Admin SetWeight Panel</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Segoe UI', sans-serif;
    background: transparent;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  #panel {
    display: none;
    pointer-events: all;
    background: #110f10;
    border: 1px solid #352a2e;
    border-radius: 12px;
    width: 580px;
    max-height: 75vh;
    overflow: hidden;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0,0,0,0.7);
  }

  #panel.visible { display: flex; }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #352a2f;
    background: #1a1316;
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .panel-title .icon {
    width: 32px;
    height: 32px;
    background: #ed3a7022;
    border: 1px solid #ed3a8e55;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  .panel-title h1 {
    font-size: 15px;
    font-weight: 600;
    color: #f0e2e7;
    letter-spacing: 0.3px;
  }

  .panel-title span {
    font-size: 12px;
    color: #8b646e;
    font-weight: 400;
  }

  .header-actions {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .btn-refresh {
    background: #2a1e23;
    border: 1px solid #352a2e;
    border-radius: 6px;
    color: #b8949f;
    font-size: 12px;
    padding: 6px 10px;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .btn-refresh:hover { background: #382a30; color: #f0e2e5; }

  .btn-close {
    background: transparent;
    border: 1px solid #352a2c;
    border-radius: 6px;
    color: #8b6470;
    font-size: 18px;
    width: 28px;
    height: 28px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    line-height: 1;
  }

  .btn-close:hover { background: #ff3b9d22; border-color: #ff3b8d55; color: #ff3b3b; }

  .search-bar {
    padding: 12px 20px;
    border-bottom: 1px solid #2a1e23;
  }

  .search-bar input {
    width: 100%;
    background: #241a1e;
    border: 1px solid #352a30;
    border-radius: 8px;
    padding: 8px 12px 8px 34px;
    color: #f0e2e8;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
  }

  .search-bar input:focus { border-color: #ed3a7f66; }
  .search-bar input::placeholder { color: #694751; }

  .search-wrap {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 14px;
    color: #694751;
    pointer-events: none;
  }

  .player-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
    scrollbar-width: thin;
    scrollbar-color: #352a2e transparent;
  }

  .player-list::-webkit-scrollbar { width: 4px; }
  .player-list::-webkit-scrollbar-track { background: transparent; }
  .player-list::-webkit-scrollbar-thumb { background: #352a2e; border-radius: 4px; }

  .player-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 8px;
    margin-bottom: 4px;
    cursor: pointer;
    transition: all 0.15s;
    border: 1px solid transparent;
  }

  .player-card:hover { background: #261a1e; border-color: #352a2c; }
  .player-card.selected { background: #30151d; border-color: #ed3a7f55; }

  .player-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ed3a70, #e54676);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .player-info {
    flex: 1;
    min-width: 0;
  }

  .player-name {
    font-size: 13px;
    font-weight: 500;
    color: #e2e8f0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .player-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: 2px;
  }

  .player-id {
    font-size: 11px;
    color: #694751;
    background: #241a1c;
    padding: 1px 5px;
    border-radius: 3px;
    border: 1px solid #352a2d;
  }

  .weight-bar-wrap {
    flex: 1;
    min-width: 0;
  }

  .weight-label {
    font-size: 11px;
    color: #8b6470;
    margin-bottom: 3px;
    display: flex;
    justify-content: space-between;
  }

  .weight-bar {
    height: 4px;
    background: #2a1e24;
    border-radius: 2px;
    overflow: hidden;
  }

  .weight-fill {
    height: 100%;
    border-radius: 2px;
    background: #ed3a7f;
    transition: width 0.3s;
  }

  .weight-fill.high { background: #f59e0b; }
  .weight-fill.over { background: #ef4444; }

  .badge-custom {
    font-size: 10px;
    background: #7c3aed22;
    border: 1px solid #7c3aed44;
    color: #fa8bb0;
    padding: 1px 5px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .empty-list {
    text-align: center;
    color: #475569;
    font-size: 13px;
    padding: 40px 0;
  }

  .set-panel {
    border-top: 1px solid #2a2a35;
    padding: 14px 20px;
    background: #13131a;
  }

  .set-panel-label {
    font-size: 12px;
    color: #8b6471;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .selected-target {
    font-size: 12px;
    color: #fa8bb0;
    font-weight: 500;
  }

  .set-row {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .weight-input-wrap {
    flex: 1;
    position: relative;
  }

  .weight-input-wrap input {
    width: 100%;
    background: #241a1d;
    border: 1px solid #352a2d;
    border-radius: 8px;
    padding: 9px 42px 9px 12px;
    color: #e2e8f0;
    font-size: 14px;
    font-weight: 500;
    outline: none;
    transition: border-color 0.15s;
  }

  .weight-input-wrap input:focus { border-color: #ed3a76; }

  .weight-unit {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 12px;
    color: #694752;
    pointer-events: none;
  }

  .preset-btns {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .btn-preset {
    background: #241a1e;
    border: 1px solid #352a2e;
    border-radius: 6px;
    color: #b894a2;
    font-size: 11px;
    padding: 7px 9px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-preset:hover { background: #382a2f; color: #f0e2e6; }

  .btn-apply {
    background: #ed3a85;
    border: none;
    border-radius: 8px;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 18px;
    cursor: pointer;
    transition: all 0.15s;
    flex-shrink: 0;
  }

  .btn-apply:hover { background: #d9286c; }
  .btn-apply:active { transform: scale(0.97); }
  .btn-apply:disabled { background: #352a2e; color: #69474e; cursor: not-allowed; }

  .toast {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(60px);
    background: #241a1f;
    border: 1px solid #352a2d;
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 13px;
    color: #e2e8f0;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: transform 0.25s ease;
    pointer-events: none;
    z-index: 999;
  }

  .toast.show { transform: translateX(-50%) translateY(0); }
  .toast.success { border-color: #22c55e44; }
  .toast.success .toast-icon { color: #22c55e; }
  .toast.error { border-color: #ef444444; }
  .toast.error .toast-icon { color: #ef4444; }

  .footer-bar {
    padding: 8px 20px;
    border-top: 1px solid #2a1e22;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #110f10;
  }

  .footer-info {
    font-size: 11px;
    color: #55333e;
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .footer-dot { width: 4px; height: 4px; border-radius: 50%; background: #334155; }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; display: inline-block; }
</style>
</head>
<body>

<div id="panel">
  <div class="panel-header">
    <div class="panel-title">
      <div class="icon">⚖️</div>
      <div>
        <h1>MEDALIXT BERAT</h1>
        <span>CUSTOM BERAT UNTUK OX INVENTORY</span>
      </div>
    </div>
    <div class="header-actions">
      <button class="btn-refresh" id="btnRefresh">
        <span id="refreshIcon">↻</span> Refresh
      </button>
      <button class="btn-close" id="btnClose">✕</button>
    </div>
  </div>

  <div class="search-bar">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Cari nama atau ID player..." />
    </div>
  </div>

  <div class="player-list" id="playerList">
    <div class="empty-list">Memuat daftar player...</div>
  </div>

  <div class="set-panel">
    <div class="set-panel-label">
      Target: <span class="selected-target" id="targetLabel">— Pilih player di atas —</span>
    </div>
    <div class="set-row">
      <div class="weight-input-wrap">
        <input type="number" id="weightInput" placeholder="Masukkan berat..." min="0" max="1000000" />
        <span class="weight-unit">kg</span>
      </div>
      <div class="preset-btns">
        <button class="btn-preset" onclick="setPreset(50)">50</button>
        <button class="btn-preset" onclick="setPreset(100)">100</button>
        <button class="btn-preset" onclick="setPreset(500)">500</button>
        <button class="btn-preset" onclick="setPreset(9999)">∞</button>
      </div>
      <button class="btn-apply" id="btnApply" disabled onclick="applyWeight()">Terapkan</button>
    </div>
  </div>

  <div class="footer-bar">
    <div class="footer-info">
      <span id="playerCount">0 player online</span>
      <div class="footer-dot"></div>
      <span>ESC untuk menutup</span>
    </div>
    <div class="footer-info" style="color:#334155">ox_inventory setweight panel</div>
  </div>
</div>

<div class="toast" id="toast">
  <span class="toast-icon" id="toastIcon">✓</span>
  <span id="toastMsg"></span>
</div>

<script>
  let players = [];
  let selectedPlayer = null;

  function getInitials(name) {
    return name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
  }

  function getWeightPercent(current, max) {
    if (!max || max === 0) return 0;
    return Math.min((current / max) * 100, 100);
  }

  function renderPlayers(list) {
    const container = document.getElementById('playerList');
    if (!list || list.length === 0) {
      container.innerHTML = '<div class="empty-list">Tidak ada player online.</div>';
      document.getElementById('playerCount').textContent = '0 player online';
      return;
    }

    document.getElementById('playerCount').textContent = `${list.length} player online`;

    container.innerHTML = list.map(p => {
      const pct = getWeightPercent(p.currentWeight, p.maxWeight);
      const fillClass = pct >= 90 ? 'over' : pct >= 70 ? 'high' : '';
      const isSelected = selectedPlayer && selectedPlayer.id === p.id;
      return `
        <div class="player-card ${isSelected ? 'selected' : ''}" data-pid="${p.id}">
          <div class="player-avatar">${getInitials(p.name)}</div>
          <div class="player-info">
            <div class="player-name">${p.name}</div>
            <div class="player-meta">
              <span class="player-id">ID: ${p.id}</span>
              ${p.isCustom ? '<span class="badge-custom">✦ Custom</span>' : ''}
            </div>
          </div>
          <div class="weight-bar-wrap">
            <div class="weight-label">
              <span>${p.currentWeight} kg</span>
              <span>${p.maxWeight} kg</span>
            </div>
            <div class="weight-bar">
              <div class="weight-fill ${fillClass}" style="width: ${pct}%"></div>
            </div>
          </div>
        </div>
      `;
    }).join('');

    container.querySelectorAll('.player-card[data-pid]').forEach(function(card) {
      card.addEventListener('click', function() {
        var pid = parseInt(this.getAttribute('data-pid'));
        selectPlayer(pid);
      });
    });
  }

  function selectPlayer(id) {
    selectedPlayer = players.find(function(p) { return p.id === id; });
    if (!selectedPlayer) return;
    document.getElementById('targetLabel').textContent = selectedPlayer.name + ' (ID: ' + selectedPlayer.id + ')';
    document.getElementById('btnApply').disabled = false;
    document.getElementById('weightInput').focus();

    document.querySelectorAll('.player-card[data-pid]').forEach(function(card) {
      var pid = parseInt(card.getAttribute('data-pid'));
      card.classList.toggle('selected', pid === id);
    });
  }

  function setPreset(value) {
    document.getElementById('weightInput').value = value;
  }

  function applyWeight() {
    if (!selectedPlayer) return;
    const weight = parseInt(document.getElementById('weightInput').value);
    if (!weight || weight <= 0) {
      showToast('Masukkan berat yang valid!', false);
      return;
    }

    document.getElementById('btnApply').disabled = true;

    fetch(`https://${getResourceName()}/setWeight`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ targetId: selectedPlayer.id, weight: weight })
    });
  }

  function getFilteredPlayers() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    if (!query) return players;
    return players.filter(p =>
      p.name.toLowerCase().includes(query) || String(p.id).includes(query)
    );
  }

  function showToast(msg, success = true) {
    const toast = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    document.getElementById('toastIcon').textContent = success ? '✓' : '✕';
    toast.className = `toast show ${success ? 'success' : 'error'}`;
    setTimeout(() => toast.className = 'toast', 2800);
  }

  document.getElementById('searchInput').addEventListener('input', function() {
    renderPlayers(getFilteredPlayers());
  });

  function closePanelUI() {
    document.getElementById('panel').classList.remove('visible');
    players = [];
    selectedPlayer = null;
    fetch('https://' + getResourceName() + '/closePanel', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}'
    });
  }

  document.getElementById('btnClose').addEventListener('click', closePanelUI);

  document.getElementById('btnRefresh').addEventListener('click', function() {
    const icon = document.getElementById('refreshIcon');
    icon.classList.add('spin');
    fetch(`https://${getResourceName()}/refreshPlayers`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}'
    });
    setTimeout(() => icon.classList.remove('spin'), 800);
  });

  document.getElementById('weightInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') applyWeight();
  });

  window.addEventListener('message', function(event) {
    const data = event.data;
    if (!data || !data.action) return;

    if (data.action === 'openPanel') {
      players = data.players || [];
      selectedPlayer = null;
      document.getElementById('targetLabel').textContent = '— Pilih player di atas —';
      document.getElementById('btnApply').disabled = true;
      document.getElementById('weightInput').value = '';
      document.getElementById('searchInput').value = '';
      document.getElementById('panel').classList.add('visible');
      renderPlayers(players);
    }

    if (data.action === 'closePanel') {
      document.getElementById('panel').classList.remove('visible');
      players = [];
      selectedPlayer = null;
    }

    if (data.action === 'setSuccess') {
      showToast('Berhasil! Berat ' + data.targetName + ' u2192 ' + data.weight + ' kg', true);
      setTimeout(closePanelUI, 1500);
    }

    if (data.action === 'setError') {
      document.getElementById('btnApply').disabled = false;
      showToast(data.message || 'Terjadi kesalahan!', false);
    }
  });

  function getResourceName() {
    try {
      return window.GetParentResourceName();
    } catch(e) {
      return 'medalixt_berat';
    }
  }
</script>
</body>
</html>
